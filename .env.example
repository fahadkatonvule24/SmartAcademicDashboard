# Main deployment settings
PORT=8000
TRANSLATION_PROVIDER=auto
COURSE_ASSISTANT_PROVIDER=auto

# Local JSON storage directories.
# Use a persistent disk/path in production if the host filesystem is ephemeral.
DATA_DIR=data
COURSE_ASSISTANT_DATA_DIR=data/course_assistant
COURSE_ASSISTANT_UPLOAD_DIR=data/course_assistant/uploads

# Optional provider language behavior
DEFAULT_SOURCE_LANGUAGE=en
FALLBACK_LANGUAGE=en
DEFAULT_BILINGUAL=true
